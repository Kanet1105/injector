[redpanda]
brokers  = "localhost:9092"
topic    = "injector.news"
group_id = "injector"

[[pollers]]
query         = "artificial intelligence"
interval_secs = 60
max_retries   = 3
hl            = "en-US"
gl            = "US"
ceid          = "US:en"

[[pollers]]
query         = "rust programming"
interval_secs = 120
max_retries   = 3
